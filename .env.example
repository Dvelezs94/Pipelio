# Session signing secret (required in production; use a long random string)
AUTH_SECRET=change_me_to_a_long_random_secret

# Browser extension scraper API key (required for POST /api/scraper/import)
SCRAPER_API_KEY=change_me_scraper_key

# Optional default workspace for the browser extension when workspaceId is not sent
# SCRAPER_WORKSPACE_ID=

# --- Supabase PostgreSQL ---
# Supabase → Project Settings → Database → Connection string → URI
# Direct connection (port 5432). Set DATABASE_URL; DIRECT_URL is optional (same value).
DATABASE_URL="postgresql://postgres:[YOUR-PASSWORD]@db.mpeejubegtwpycpsetmf.supabase.co:5432/postgres?sslmode=require"
# DIRECT_URL="postgresql://postgres:[YOUR-PASSWORD]@db.mpeejubegtwpycpsetmf.supabase.co:5432/postgres?sslmode=require"

# Optional: transaction pooler (port 6543) for high-traffic / serverless — use instead of direct URL above
# DATABASE_URL="postgresql://postgres.mpeejubegtwpycpsetmf:[PASSWORD]@aws-0-[REGION].pooler.supabase.com:6543/postgres?pgbouncer=true"

# Optional: Supabase project URL and keys (only if you add Supabase Auth/Storage later)
# NEXT_PUBLIC_SUPABASE_URL=https://mpeejubegtwpycpsetmf.supabase.co
# NEXT_PUBLIC_SUPABASE_ANON_KEY=
# SUPABASE_SERVICE_ROLE_KEY=

# Optional: Google Maps API key (only needed for map view on legacy results with coordinates)
GOOGLE_MAPS_API_KEY=your_google_maps_api_key

# Product Hunt developer token (free at https://api.producthunt.com/v2/oauth/applications)
PRODUCT_HUNT_TOKEN=your_product_hunt_developer_token

# GitHub personal access token (recommended for org search rate limits)
GITHUB_TOKEN=your_github_token

# Apify token for Clutch agency listings (https://apify.com/curious_coder/clutch-scraper)
APIFY_TOKEN=your_apify_token

# DeepSeek API key for CRM cold email generation (optional; get from https://platform.deepseek.com)
DEEPSEEK_API_KEY=your_deepseek_api_key

# SMTP/IMAP is configured in the CRM UI (Mail server settings) and stored in the database.
# Typical values: SMTP host/port, IMAP host/port, username, password, from email.

# Background IMAP inbox sync interval in milliseconds (default: 300000 = 5 minutes)
CRM_INBOX_SYNC_INTERVAL_MS=300000
